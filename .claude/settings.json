{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Committed. Two enforcement layers, and they cover different ground. The PreToolUse hook .claude/hooks/guard.js is the primary one: it receives the absolute path Claude Code is about to touch, so it blocks regardless of which repo is the session root, and a PreToolUse denial holds even under bypassPermissions. It is written in Node because Node exists on both Windows and the routine's Linux container; a hook that cannot execute exits non-zero-but-not-2, which Claude Code treats as a non-blocking error, so the tool call proceeds and the guard fails open. The permission rules below are the second layer. Their path patterns anchor to the session's working directory and only the root repo's settings file loads, so do not rely on them for the sibling repo. Bash and PowerShell are separate tools, so every command rule appears twice. The push gate is an ask rule in settings.local.json, never here: an ask rule in an unattended run resolves to a denial and the night shift would never push.",
  "permissions": {
    "deny": [
      "Edit(fellboard.html)",
      "Write(fellboard.html)",
      "Edit(docs/fellboard.html)",
      "Write(docs/fellboard.html)",
      "Edit(embeds/fellboard.html)",
      "Write(embeds/fellboard.html)",
      "Edit(scripts/**)",
      "Write(scripts/**)",
      "Edit(schemas/**)",
      "Write(schemas/**)",
      "Edit(velo/**)",
      "Write(velo/**)",
      "Edit(docs/rules.js)",
      "Write(docs/rules.js)",
      "Edit(_Canon/CANON.md)",
      "Write(_Canon/CANON.md)",
      "Edit(_Canon/STYLE.md)",
      "Write(_Canon/STYLE.md)",
      "Edit(_Canon/NAV_ORDER_MAP.md)",
      "Write(_Canon/NAV_ORDER_MAP.md)",
      "Edit(_Canon/SEASON_BIBLE.md)",
      "Write(_Canon/SEASON_BIBLE.md)",
      "Edit(_Canon/ROUTINE_PROMPT.md)",
      "Write(_Canon/ROUTINE_PROMPT.md)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Edit(Archive/**)",
      "Write(Archive/**)",
      "Edit(.obsidian/**)",
      "Write(.obsidian/**)",
      "Edit(.github/workflows/**)",
      "Write(.github/workflows/**)",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Bash(git push --force:*)",
      "PowerShell(git push --force:*)",
      "Bash(git push -f:*)",
      "PowerShell(git push -f:*)",
      "Bash(git push origin +:*)",
      "PowerShell(git push origin +:*)",
      "Bash(git reset --hard:*)",
      "PowerShell(git reset --hard:*)",
      "Bash(git clean:*)",
      "PowerShell(git clean:*)",
      "Bash(gh secret:*)",
      "PowerShell(gh secret:*)",
      "Bash(gh workflow run:*)",
      "PowerShell(gh workflow run:*)",
      "Bash(node -e:*)",
      "PowerShell(node -e:*)",
      "Bash(node --eval:*)",
      "PowerShell(node --eval:*)",
      "Bash(npx:*)",
      "PowerShell(npx:*)",
      "Bash(npm run:*)",
      "PowerShell(npm run:*)"
    ],
    "allow": [
      "Read(**)",
      "Edit(docs/**)",
      "Write(docs/**)",
      "Edit(embeds/**)",
      "Write(embeds/**)",
      "Edit(fellboard.test.js)",
      "Write(fellboard.test.js)",
      "Bash(git status:*)",
      "PowerShell(git status:*)",
      "Bash(git diff:*)",
      "PowerShell(git diff:*)",
      "Bash(git log:*)",
      "PowerShell(git log:*)",
      "Bash(git show:*)",
      "PowerShell(git show:*)",
      "Bash(git add:*)",
      "PowerShell(git add:*)",
      "Bash(git commit:*)",
      "PowerShell(git commit:*)",
      "Bash(git pull:*)",
      "PowerShell(git pull:*)",
      "Bash(git fetch:*)",
      "PowerShell(git fetch:*)",
      "Bash(git checkout:*)",
      "PowerShell(git checkout:*)",
      "Bash(git switch:*)",
      "PowerShell(git switch:*)",
      "Bash(git branch:*)",
      "PowerShell(git branch:*)",
      "Bash(git stash:*)",
      "PowerShell(git stash:*)",
      "Bash(git mv:*)",
      "PowerShell(git mv:*)",
      "Bash(git restore:*)",
      "PowerShell(git restore:*)",
      "Bash(git push:*)",
      "PowerShell(git push:*)",
      "Bash(node fellboard.test.js)",
      "PowerShell(node fellboard.test.js)",
      "Bash(node scripts/checkContracts.js)",
      "PowerShell(node scripts/checkContracts.js)",
      "Bash(node scripts/build.js)",
      "PowerShell(node scripts/build.js)",
      "Bash(npm test:*)",
      "PowerShell(npm test:*)",
      "Bash(gh run list:*)",
      "PowerShell(gh run list:*)",
      "Bash(gh run view:*)",
      "PowerShell(gh run view:*)",
      "Bash(gh pr create:*)",
      "PowerShell(gh pr create:*)",
      "Bash(gh pr view:*)",
      "PowerShell(gh pr view:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash|PowerShell|Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
